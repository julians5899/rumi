# ============================================================
# Rumi - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Stage: localdev | dev | prod
# localdev = no AWS, local JWT auth
# dev/prod = AWS Cognito auth
STAGE=localdev
VITE_STAGE=localdev

# Database
DATABASE_URL=postgresql://your_user:password@localhost:5432/rumi

# Local auth JWT secret (only needed for localdev)
JWT_SECRET=rumi-local-dev-secret-change-me-in-prod

# AWS (only needed for dev/prod)
AWS_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1

# Cognito (only needed for dev/prod)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=

# S3
IMAGES_BUCKET=

# API
API_PORT=3000
API_BASE_URL=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3000
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
