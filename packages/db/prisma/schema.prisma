generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS
// ============================================================
model User {
  id         String      @id @default(uuid())
  cognitoSub String      @unique @map("cognito_sub")
  email      String      @unique
  firstName  String      @map("first_name")
  lastName   String      @map("last_name")
  password   String?     // bcrypt hash, only used in localdev stage
  phone      String?
  avatarUrl  String?     @map("avatar_url")
  bio        String?
  age          Int?
  dateOfBirth  DateTime?   @map("date_of_birth")
  occupation   String?
  nationality  String?
  gender       Gender?
  language     String[]    @default([])
  preferences  Json?       // User preferences (lookingFor, myTraits, idealRoommate)
  seekingMode SeekingMode @default(NONE) @map("seeking_mode")
  deletedAt  DateTime?   @map("deleted_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  // Relations
  properties            Property[]
  propertyViews         PropertyView[]
  roommateProfile       RoommateProfile?
  sentSwipes            Swipe[]            @relation("SwipeSender")
  receivedSwipes        Swipe[]            @relation("SwipeReceiver")
  sentApplications      Application[]      @relation("Applicant")
  conversations1        Conversation[]     @relation("Participant1")
  conversations2        Conversation[]     @relation("Participant2")
  messages              Message[]
  ratingsGiven          Rating[]           @relation("Rater")
  ratingsReceived       Rating[]           @relation("RatedUser")
  confirmedAppointments Appointment[]      @relation("ConfirmedBy")
  availabilitySlots     AvailabilitySlot[]
  uploadedDocuments     Document[]
  tenantLeases          Lease[]            @relation("Tenant")

  @@map("users")
}

enum SeekingMode {
  NONE
  TENANT
  ROOMMATE
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================================
// PROPERTIES
// ============================================================
model Property {
  id           String       @id @default(uuid())
  ownerId      String       @map("owner_id")
  title        String
  description  String
  propertyType PropertyType @map("property_type")
  listingType  ListingType  @map("listing_type")
  price        Decimal      @db.Decimal(12, 2)
  currency     String       @default("COP")
  bedrooms     Int
  bathrooms    Int
  area         Decimal?     @db.Decimal(10, 2)
  address      String
  city         String
  neighborhood String?
  department   String
  latitude     Decimal?     @db.Decimal(10, 8)
  longitude    Decimal?     @db.Decimal(11, 8)
  amenities    String[]
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  owner        User           @relation(fields: [ownerId], references: [id])
  images       PropertyImage[]
  views        PropertyView[]
  applications Application[]
  leases       Lease[]

  @@index([city, isActive])
  @@index([ownerId])
  @@index([propertyType, listingType])
  @@map("properties")
}

enum PropertyType {
  APARTMENT
  HOUSE
  ROOM
  STUDIO
}

enum ListingType {
  RENT
  SALE
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

// ============================================================
// PROPERTY VIEWS (track seen properties)
// ============================================================
model PropertyView {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("property_views")
}

// ============================================================
// ROOMMATE MATCHING
// ============================================================
model RoommateProfile {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  budget                 Decimal  @db.Decimal(12, 2)
  preferredCity          String   @map("preferred_city")
  preferredNeighborhoods String[] @map("preferred_neighborhoods")
  moveInDate             DateTime? @map("move_in_date")
  bio                    String?
  occupation             String?
  age                    Int?
  lifestyle              Json?
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("roommate_profiles")
}

model Swipe {
  id         String      @id @default(uuid())
  senderId   String      @map("sender_id")
  receiverId String      @map("receiver_id")
  action     SwipeAction
  createdAt  DateTime    @default(now()) @map("created_at")

  sender   User @relation("SwipeSender", fields: [senderId], references: [id])
  receiver User @relation("SwipeReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, action])
  @@map("swipes")
}

enum SwipeAction {
  LIKE
  PASS
}

model Match {
  id        String   @id @default(uuid())
  user1Id   String   @map("user1_id")
  user2Id   String   @map("user2_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("matches")
}

// ============================================================
// MESSAGING
// ============================================================
model Conversation {
  id             String    @id @default(uuid())
  participant1Id String    @map("participant1_id")
  participant2Id String    @map("participant2_id")
  lastMessageAt  DateTime? @map("last_message_at")
  blockedAt      DateTime? @map("blocked_at")
  deletedByP1At  DateTime? @map("deleted_by_p1_at")
  deletedByP2At  DateTime? @map("deleted_by_p2_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id])
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id])
  messages     Message[]

  @@unique([participant1Id, participant2Id])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  content        String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// APPLICATIONS (tenant applies to a property)
// ============================================================
model Application {
  id          String            @id @default(uuid())
  propertyId  String            @map("property_id")
  applicantId String            @map("applicant_id")
  message     String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  property    Property    @relation(fields: [propertyId], references: [id])
  applicant   User        @relation("Applicant", fields: [applicantId], references: [id])
  appointment Appointment?
  documents   Document[]
  lease       Lease?

  @@unique([propertyId, applicantId])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// ============================================================
// RATINGS (multi-context scoring system)
// ============================================================
model Rating {
  id          String        @id @default(uuid())
  raterId     String        @map("rater_id")
  ratedUserId String        @map("rated_user_id")
  context     RatingContext
  score       Int
  comment     String?
  createdAt   DateTime      @default(now()) @map("created_at")

  rater     User @relation("Rater", fields: [raterId], references: [id])
  ratedUser User @relation("RatedUser", fields: [ratedUserId], references: [id])

  @@unique([raterId, ratedUserId, context])
  @@index([ratedUserId, context])
  @@map("ratings")
}

enum RatingContext {
  LANDLORD
  TENANT
  ROOMMATE
}

// ============================================================
// WORKFLOW: APPOINTMENTS (post-application acceptance)
// ============================================================
model Appointment {
  id              String            @id @default(uuid())
  applicationId   String            @unique @map("application_id")
  status          AppointmentStatus @default(SCHEDULING)
  confirmedStart  DateTime?         @map("confirmed_start")
  confirmedEnd    DateTime?         @map("confirmed_end")
  confirmedById   String?           @map("confirmed_by_id")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  application       Application        @relation(fields: [applicationId], references: [id])
  confirmedByUser   User?              @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  availabilitySlots AvailabilitySlot[]

  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model AvailabilitySlot {
  id            String   @id @default(uuid())
  appointmentId String   @map("appointment_id")
  userId        String   @map("user_id")
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([appointmentId])
  @@map("availability_slots")
}

// ============================================================
// WORKFLOW: DOCUMENTS (post-appointment completion)
// ============================================================
model Document {
  id            String         @id @default(uuid())
  applicationId String         @map("application_id")
  uploadedById  String         @map("uploaded_by_id")
  type          DocumentType
  status        DocumentStatus @default(PENDING)
  fileKey       String         @map("file_key")
  fileName      String         @map("file_name")
  fileSize      Int            @map("file_size")
  mimeType      String         @map("mime_type")
  rejectionNote String?        @map("rejection_note")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id])
  uploadedBy  User        @relation(fields: [uploadedById], references: [id])

  @@index([applicationId])
  @@map("documents")
}

enum DocumentType {
  CC
  WORK_CERT
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// WORKFLOW: LEASES (final step — formal contract)
// ============================================================
model Lease {
  id            String      @id @default(uuid())
  applicationId String      @unique @map("application_id")
  tenantId      String      @map("tenant_id")
  propertyId    String      @map("property_id")
  startDate     DateTime    @map("start_date")
  endDate       DateTime    @map("end_date")
  monthlyRent   Decimal     @map("monthly_rent") @db.Decimal(12, 2)
  status        LeaseStatus @default(ACTIVE)
  signedAt      DateTime?   @map("signed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id])
  tenant      User        @relation("Tenant", fields: [tenantId], references: [id])
  property    Property    @relation(fields: [propertyId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@map("leases")
}

enum LeaseStatus {
  ACTIVE
  ENDED
  CANCELLED
}
