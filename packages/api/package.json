{
  "name": "@rumi/api",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/lambda.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist/lambda.js --external:@prisma/client --external:@prisma/engines --sourcemap",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/aws-lambda": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "aws-jwt-verify": "^4.0.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@rumi/shared": "*",
    "@rumi/db": "*",
    "zod": "^3.24.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0"
  }
}
